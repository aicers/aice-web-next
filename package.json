{
  "name": "aice-web-next",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "check": "biome ci --error-on-warnings .",
    "check:scope": "node scripts/check-dispatch-context.mjs",
    "fix": "biome check --write src",
    "markdownlint": "markdownlint-cli2 '**/*.md'",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "codegen:detection": "node scripts/codegen-detection-types.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.73.1",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0",
    "undici": "^8.1.0",
    "world-atlas": "^2.0.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "jsdom": "^29.1.0",
    "markdownlint-cli2": "^0.22.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
