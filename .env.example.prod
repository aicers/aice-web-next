# ════════════════════════════════════════════════════════════════
# PROD COMPOSE — `docker compose --profile prod up -d`
# ════════════════════════════════════════════════════════════════
# The prod compose profile passes this file directly into the
# `next-app` container, so every DSN must use the compose-network
# hostnames (e.g. `postgres:5432`), NOT host-side `localhost`
# addresses. The startup guard aborts boot if any PostgreSQL DSN
# points at `localhost`, `127.0.0.1`, or `::1`.
#
# For host-side dev (`pnpm dev`, psql, the Vitest integration
# suite, etc.) start from `.env.example` instead.
#
# Required first-boot values are left BLANK with a comment.
# Anything that must be set for a fresh prod boot to succeed is
# called out below. See README → "First-boot deployment
# checklist".

# ── Prod compose marker ─────────────────────────────────────────
# Must stay set on the prod compose profile. Keys the startup
# environment guards (DSN hostnames, EXPECTED_ORIGIN) so they run
# only for prod compose deployments and not for other production
# paths (e.g. local image smoke-tests, K8s rollouts that ship a
# different env shape).
AICE_ENV_PROFILE=prod-compose

# ════════════════════════════════════════════════════════════════
# Upstream GraphQL endpoints
# ════════════════════════════════════════════════════════════════
# The host portion of each URL must match the SAN on that
# upstream's server certificate (mTLS), and that hostname must
# resolve from inside the `next-app` container. See README →
# "Upstream FQDN resolution".
REVIEW_GRAPHQL_ENDPOINT=
GIGANTO_GRAPHQL_ENDPOINT=
TIVAN_GRAPHQL_ENDPOINT=

# ── Client mTLS material ────────────────────────────────────────
# See README → "mTLS upstream certificate mount" for the
# bind-mount + uid 1001 permission pattern, and
# `docs/en/operations/mtls-rotation.md` for in-place rotation.
MTLS_CERT_PATH=
MTLS_KEY_PATH=
MTLS_CA_PATH=

# ════════════════════════════════════════════════════════════════
# PostgreSQL DSNs (compose-network addresses)
# ════════════════════════════════════════════════════════════════
# Inside the `next-app` container `localhost` is the container
# itself — these DSNs must use the compose-network service name
# `postgres`. Boot fails fast if any DSN points at localhost /
# 127.0.0.1 / ::1.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/auth_db
DATABASE_ADMIN_URL=postgres://postgres:postgres@postgres:5432/postgres
AUDIT_DATABASE_URL=postgres://audit_writer:changeme@postgres:5432/audit_db

DATA_DIR=/app/data
JWT_EXPIRATION_MINUTES=15

# ════════════════════════════════════════════════════════════════
# CSRF / Origin guard
# ════════════════════════════════════════════════════════════════
# REQUIRED on the prod compose path: browsers send
# `Origin: https://your.host[:port]` while the upstream Next.js
# only sees `request.nextUrl.origin === "http://..."`, so the
# mutation guard would reject every POST/PUT/PATCH/DELETE.
#
# Must be an exact HTTP(S) origin: `http://` or `https://` scheme
# + host + optional port only, with no path, query, or fragment.
# Canonicalization at parse time strips a trailing slash and
# lowercases scheme/host; anything with a path component
# (e.g. `https://host/app`) or a non-HTTP(S) scheme
# (e.g. `ftp://`, `ws://`) is rejected and boot fails. The default `nginx-prod` host-port
# mapping is `9443:443`, so a fresh prod boot on the host itself
# should use `https://localhost:9443`.
EXPECTED_ORIGIN=

CSRF_SECRET=

# ── Initial System Administrator ───────────────────────────────
# REQUIRED for first boot when the `accounts` table is empty.
# Boot fails loudly if both are unset/blank and no Docker secret
# files exist at /run/secrets/init_admin_{username,password},
# so a fresh prod boot cannot silently start without an admin.
INIT_ADMIN_USERNAME=
INIT_ADMIN_PASSWORD=

DEFAULT_LOCALE=en

# ── WebAuthn relying-party identity ─────────────────────────────
# WEBAUTHN_RP_ID is the eTLD+1-aligned host (no scheme, no port).
# WEBAUTHN_RP_ORIGIN is the full public origin browsers use and
# must match what the browser sends in the WebAuthn ceremony.
#
#   EXPECTED_ORIGIN=https://your.public.host:9443
#   WEBAUTHN_RP_ORIGIN=https://your.public.host:9443
#   WEBAUTHN_RP_ID=your.public.host
#
# Leaving WEBAUTHN_RP_ORIGIN at its dev fallback (BASE_URL or
# http://localhost:3000) silently breaks MFA enrollment on the
# prod profile.
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=AICE
WEBAUTHN_RP_ORIGIN=

# ── JWT signing key ─────────────────────────────────────────────
# Option A — externally managed key file (recommended for prod).
#   Point at a key JSON written by `pnpm gen-jwt-key` or rendered
#   from a Secret/Vault csi mount. The previous key (for
#   rotation) continues to load from
#   `<DATA_DIR>/keys/jwt-signing.prev.json` unless
#   JWT_SIGNING_KEY_FILE_PREVIOUS is also set.
# JWT_SIGNING_KEY_FILE=
# JWT_SIGNING_KEY_FILE_PREVIOUS=
#
# Option B — first-boot autogen (single-instance convenience).
#   Set to "1" / "true" / "on" / "yes" to generate
#   `<DATA_DIR>/keys/jwt-signing.json` on first boot if missing.
#   Multi-replica deployments MUST NOT use this — each replica
#   would generate its own key independently.
# JWT_SIGNING_KEY_AUTOGEN=

# ── Triage engagement-signal pseudonymization (#588) ────────────
# HMAC key for pseudonymizing pivot values, asset addresses, and
# `account_id` before they land in the engagement tables. Set to
# base64 of ≥32 random bytes (e.g. `openssl rand -base64 48`).
# The key does NOT rotate — rotating invalidates every historical
# row's join key. See `src/lib/triage/engagement/hmac.ts`.
ENGAGEMENT_HMAC_KEY=

# Shared secret for the internal engagement retention route at
# POST /api/internal/triage/engagement/retention. The in-repo
# cron service (`run-triage-engagement-retention.sh`, daily at
# 05:15 UTC) must include `Authorization: Bearer <token>`
# matching this value. If unset, the route refuses every request
# and the engagement tables grow unbounded.
TRIAGE_ENGAGEMENT_RETENTION_INTERNAL_TOKEN=

# ── ApplyAttempt lifecycle (Phase Node-9a, #359) ────────────────
# Execution deadline for a non-terminal apply attempt. Default
# 30 minutes.
APPLY_ATTEMPT_TTL_MS=1800000
# Retention horizon for a terminal apply attempt before
# hard-delete. Default 7 days.
APPLY_ATTEMPT_RETENTION_MS=604800000
# Stale-lock recovery threshold for `executing` apply attempts.
# Default 2.5 hours.
APPLY_EXECUTING_STALE_MS=9000000
# Per-dispatch retry cap before `failed_terminal`. Default 3.
APPLY_DISPATCH_MAX_ATTEMPTS=3
# Shared secret for POST /api/internal/apply-attempts/cleanup.
# Route refuses every request if unset.
APPLY_INTERNAL_CLEANUP_TOKEN=
# Shared secret for the internal Triage baseline cadence and
# dispatch routes. The deployment scheduler / cron service must
# include `Authorization: Bearer <token>` matching this value.
TRIAGE_BASELINE_CADENCE_INTERNAL_TOKEN=

# Triage baseline dispatcher concurrency cap (#487).
# TRIAGE_BASELINE_DISPATCH_CONCURRENCY=4
# Per-customer dispatcher timeout (ms). Default 900000.
# TRIAGE_BASELINE_DISPATCH_PER_CUSTOMER_TIMEOUT_MS=900000
# Total dispatcher timeout (ms). Must stay below 900000. Default
# 840000.
# TRIAGE_BASELINE_DISPATCH_TOTAL_TIMEOUT_MS=840000
# Override the cron service's base URL for the dispatcher route.
# Defaults to `http://next-app:3000`.
# NEXT_APP_BASE_URL=http://next-app:3000

# ════════════════════════════════════════════════════════════════
# Internal scheduled-job / route bearer tokens
# ════════════════════════════════════════════════════════════════
# Shared secrets the internal-API routes match against the
# `Authorization: Bearer <token>` header. Each route refuses every
# request (and its caller refuses to fire) when its token is unset,
# so a fresh prod boot leaves the corresponding job dormant until an
# operator supplies a value out-of-band. `TRIAGE_ENGAGEMENT_RETENTION_
# INTERNAL_TOKEN`, `TRIAGE_BASELINE_CADENCE_INTERNAL_TOKEN`, and
# `APPLY_INTERNAL_CLEANUP_TOKEN` are declared above, next to their
# feature blocks; the rest are listed here.
#
# ── Cron-wrapper tokens (infra/cron/run-*.sh) ───────────────────
# Corpus A retention — run-triage-baseline-retention.sh, 03:15 UTC.
TRIAGE_BASELINE_RETENTION_INTERNAL_TOKEN=
# Condition-snapshot retention — run-triage-snapshot-retention.sh,
# 04:15 UTC.
TRIAGE_SNAPSHOT_RETENTION_INTERNAL_TOKEN=
# Corpus B retention + zombie reaper — run-triage-policy-retention.sh,
# every 6h.
TRIAGE_POLICY_RETENTION_INTERNAL_TOKEN=
# Exclusion fan-out queue drain — run-triage-exclusion-fanout.sh,
# every minute.
TRIAGE_EXCLUSION_FANOUT_TOKEN=
# Aimer Phase 2 manual-mint retention —
# run-aimer-phase2-manual-mint-retention.sh, 06:15 UTC.
AIMER_PHASE2_MANUAL_MINT_RETENTION_INTERNAL_TOKEN=
#
# ── Operator-triggered route tokens (no wrapper) ────────────────
# These routes have no scheduled wrapper; an operator invokes them
# out-of-band (backfill / recovery / rebuild). They still require a
# bearer token, so declare it here for completeness.
# Aimer Phase 2 backfill (src/lib/aimer/phase2/backfill.ts).
AIMER_PHASE2_BACKFILL_INTERNAL_TOKEN=
# Exclusion recovery sweep (src/lib/triage/exclusion/recovery.ts).
TRIAGE_EXCLUSION_RECOVERY_INTERNAL_TOKEN=
# Story rebuild (src/lib/triage/story/rebuild.ts).
TRIAGE_STORY_REBUILD_INTERNAL_TOKEN=

# ════════════════════════════════════════════════════════════════
# Tunables
# ════════════════════════════════════════════════════════════════
# Polling cadence for the Nodes Status tab and detail-page
# dashboard, in milliseconds. Default 10000. Values outside
# [5000, 300000] clamp at the call site.
NEXT_PUBLIC_NODE_STATUS_POLL_MS=10000

# Set to "1", "true", or "on" to ship the gs-build subset of the
# Hog `active_models` list. Anything else (or unset) ships the
# full set.
NEXT_PUBLIC_GS_MODE=
